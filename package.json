{
  "name": "taski-ai-incident-triage",
  "version": "0.1.0",
  "private": true,
  "description": "Contract-first Azure Monitor incident triage foundation for Taski.",
  "main": "dist/src/functions/*.js",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest",
    "test:run": "vitest run",
    "replay:alert": "tsx scripts/replayAlert.ts",
    "demo:triage": "tsx scripts/runTriageDemo.ts"
  },
  "dependencies": {
    "@azure/functions": "^4.16.2",
    "@openai/agents": "^0.13.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
